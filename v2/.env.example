# =============================
# v2 local environment template
# Fill these values before running producer/streaming jobs.
# =============================

# Global environment
APP_ENV=dev
RUN_ID=v2_baseline_real_backlog_2026_03_16

# -----------------------------
# ProducerConfig (v2/src/producer/config.py)
# -----------------------------
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
KAFKA_RAW_TOPIC=twitch_chat_raw
KAFKA_CLIENT_ID=twitch-raw-producer-v2
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
API_KEY=replace_with_confluent_api_key
API_SECRET=replace_with_confluent_api_secret
KAFKA_RETRIES=10
KAFKA_RETRY_BACKOFF_MS=500
PRODUCER_POLL_TIMEOUT_SECONDS=30

TWITCH_SERVER=irc.chat.twitch.tv
TWITCH_PORT=6667
TWITCH_NICK=your_twitch_bot_username
TWITCH_TOKEN=oauth:replace_me
TWITCH_CHANNEL=replace_with_channel

# -----------------------------
# StreamingJobConfig (v2/src/streaming/utils/config_loader.py)
# -----------------------------
BRONZE_TABLE=twitch_pipeline.bronze_chat_raw
SILVER_PARSED_TABLE=twitch_pipeline.silver_chat_parsed
SILVER_FEATURES_TABLE=twitch_pipeline.silver_chat_features
DLQ_TABLE=twitch_pipeline.chat_dlq
OPS_METRICS_TABLE=twitch_pipeline.ops.streaming_batch_metrics

# Checkpoints (must be durable paths in real deployments)
BRONZE_CHECKPOINT=/tmp/twitch_pipeline/checkpoints/bronze
SILVER_PARSE_CHECKPOINT=/tmp/twitch_pipeline/checkpoints/silver_parse
SILVER_FEATURES_CHECKPOINT=/tmp/twitch_pipeline/checkpoints/silver_features

# Behavior flags
ENFORCE_FAIL_FAST=true

# Twitch OAuth app client id (used by local_token_redirect.py)
TWITCH_CLIENT_ID=replace_with_twitch_app_client_id

# Silver canonical dedupe state bound
SILVER_DEDUPE_WATERMARK=24 hours
